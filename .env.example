# AccOps Agent Environment Variables

# Anthropic API Key (required for LLM integration)
ANTHROPIC_API_KEY=your_api_key_here

# Accelerator Configuration
# Path to accelerator configuration file
ACCELERATOR_CONFIG=configs/accelerators/example_linac.yaml

# Tao Configuration
# Path to Tao initialization file (if using real Tao backend)
TAO_INIT_FILE=

# Backend Selection
# Options: "mock" or "pytao"
BACKEND=mock

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/accops_agent.log

# LangGraph Configuration
# Thread ID for state persistence
THREAD_ID=default

# Safety Settings
# Enable safety checks
ENABLE_SAFETY_CHECKS=true

# Maximum iterations for optimization loops
MAX_ITERATIONS=10
